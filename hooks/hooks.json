{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*(browser|chrome|computer).*(click|type|fill|select|upload|press|key|input|form).*|.*(click|type|fill|select|upload|press).*(browser|chrome|computer).*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/workflow-gate.sh\""
          }
        ]
      },
      {
        "matcher": ".*(browser|chrome|computer).*(navigate|goto|open_url).*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/navigate-warn.sh\""
          }
        ]
      }
    ]
  }
}
